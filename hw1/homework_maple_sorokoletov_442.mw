<?xml version="1.0" encoding="utf-8"?>
<Worksheet namespace="urn:schemas-maplesoft-com:worksheet.8.1">
  <Styles>
    <Style name="Maple Input" layout="Normal" prompt="&gt; "/>
    <Style name="Text" layout="Normal"/>
  </Styles>
  
  <Group>
    <Input>
      <Text-field style="Text">Homework: Vector Fields</Text-field>
      <Text-field style="Text">Student: Sorokoletov D.S., 442</Text-field>
    </Input>
  </Group>

  <Group>
    <Input>
      <Text-field prompt="&gt; " style="Maple Input">restart;</Text-field>
      <Text-field prompt="&gt; " style="Maple Input">with(DifferentialGeometry):</Text-field>
      <Text-field prompt="&gt; " style="Maple Input">with(LinearAlgebra):</Text-field>
      <Text-field prompt="&gt; " style="Maple Input">DGsetup([x, y, phi], M);</Text-field>
    </Input>
  </Group>

  <Group>
    <Input>
      <Text-field prompt="&gt; " style="Maple Input">X := evalDG(cos(phi)*D_x + sin(phi)*D_y);</Text-field>
      <Text-field prompt="&gt; " style="Maple Input">Y := evalDG(D_phi);</Text-field>
    </Input>
  </Group>

  <Group>
    <Input>
      <Text-field prompt="&gt; " style="Maple Input">Z := LieBracket(X, Y);</Text-field>
      <Text-field prompt="&gt; " style="Maple Input">print("Commutator [X, Y]:", Z);</Text-field>
    </Input>
  </Group>

  <Group>
    <Input>
      <Text-field prompt="&gt; " style="Maple Input">C_X := [cos(phi), sin(phi), 0];</Text-field>
      <Text-field prompt="&gt; " style="Maple Input">C_Y := [0, 0, 1];</Text-field>
      <Text-field prompt="&gt; " style="Maple Input">C_Z := [sin(phi), -cos(phi), 0];</Text-field>
      <Text-field prompt="&gt; " style="Maple Input">Mat := Matrix([C_X, C_Y, C_Z]);</Text-field>
      <Text-field prompt="&gt; " style="Maple Input">Det := simplify(Determinant(Mat));</Text-field>
      <Text-field prompt="&gt; " style="Maple Input">print("Matrix Determinant:", Det);</Text-field>
    </Input>
  </Group>

  <Group>
    <Input>
      <Text-field prompt="&gt; " style="Maple Input">A := [x0, y0, phi0];</Text-field>
      <Text-field prompt="&gt; " style="Maple Input">B := [x1, y1, phi1];</Text-field>
      <Text-field prompt="&gt; " style="Maple Input">F_Y := Flow(Y, t_param);</Text-field>
      <Text-field prompt="&gt; " style="Maple Input">F_X := Flow(X, s_param);</Text-field>
      <Text-field prompt="&gt; " style="Maple Input">theta := arctan(y1 - y0, x1 - x0);</Text-field>
      <Text-field prompt="&gt; " style="Maple Input">t1 := theta - phi0;</Text-field>
      <Text-field prompt="&gt; " style="Maple Input">s1 := sqrt((x1 - x0)^2 + (y1 - y0)^2);</Text-field>
      <Text-field prompt="&gt; " style="Maple Input">t2 := phi1 - theta;</Text-field>
      <Text-field prompt="&gt; " style="Maple Input">P1_expr := ApplyTransformation(F_Y, A);</Text-field>
      <Text-field prompt="&gt; " style="Maple Input">P1 := simplify(eval(P1_expr, t_param = t1)) assuming real;</Text-field>
      <Text-field prompt="&gt; " style="Maple Input">P2_expr := ApplyTransformation(F_X, P1);</Text-field>
      <Text-field prompt="&gt; " style="Maple Input">P2 := simplify(eval(P2_expr, s_param = s1)) assuming real;</Text-field>
      <Text-field prompt="&gt; " style="Maple Input">FinalPoint_expr := ApplyTransformation(F_Y, P2);</Text-field>
      <Text-field prompt="&gt; " style="Maple Input">FinalPoint := simplify(eval(FinalPoint_expr, t_param = t2)) assuming real;</Text-field>
      <Text-field prompt="&gt; " style="Maple Input">print("Final Point:", FinalPoint);</Text-field>
    </Input>
  </Group>

  <Group>
    <Input>
      <Text-field prompt="&gt; " style="Maple Input">Difference := simplify([FinalPoint[1] - B[1], FinalPoint[2] - B[2], FinalPoint[3] - B[3]]) assuming real;</Text-field>
      <Text-field prompt="&gt; " style="Maple Input">print("Difference (must be [0,0,0]):", Difference);</Text-field>
    </Input>
  </Group>

  <Group>
    <Input>
      <Text-field prompt="&gt; " style="Maple Input">Test_A := [0, 0, 0];</Text-field>
      <Text-field prompt="&gt; " style="Maple Input">Test_B := [5, -3, Pi];</Text-field>
      <Text-field prompt="&gt; " style="Maple Input">Test_Final := eval(FinalPoint, [x0=Test_A[1], y0=Test_A[2], phi0=Test_A[3], x1=Test_B[1], y1=Test_B[2], phi1=Test_B[3]]);</Text-field>
      <Text-field prompt="&gt; " style="Maple Input">Test_Final := simplify(Test_Final);</Text-field>
      <Text-field prompt="&gt; " style="Maple Input">print("Test Result (must be [5, -3, Pi]):", Test_Final);</Text-field>
    </Input>
  </Group>
</Worksheet>